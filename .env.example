# ================================================================
# ML-TRM machine-local config. Copy this file to .env and fill in.
# .env is gitignored — never commit real secrets.
#
# Usage:
#   cp .env.example .env
#   # edit .env to set at least WANDB_API_KEY
#   python start.py
# ================================================================

# --- Weights & Biases -------------------------------------------
# Get your key from https://wandb.ai/authorize
# This key also authorizes Weave monitors at wandb.ai/<entity>/<project>/weave/monitors
WANDB_API_KEY=

# Optional: your wandb username or team entity (blank = use default from `wandb login`)
TRM_WANDB_ENTITY=

# Optional: override the wandb project set in YAML
# (leave blank unless you want one project for all trainers regardless of config)
TRM_WANDB_PROJECT=

# --- HuggingFace Hub (optional checkpoint backup) ---------------
# Only needed if you want to push checkpoints. Blank = disable HF sync.
HF_TOKEN=
TRM_HF_REPO_ID=

# --- Local paths ------------------------------------------------
# Optional: external drive / backup location for crash-recovery checkpoints.
# Blank = disable rolling backup.
# Examples:
#   D:/ml-trm-checkpoints          (Windows)
#   /mnt/backup/ml-trm             (Linux)
#   /Volumes/External/ml-trm       (macOS)
TRM_ROLLING_CHECKPOINT_DIR=

# Optional: move data / checkpoint dirs off the repo (e.g. shared RAID)
TRM_DATA_DIR=
TRM_CHECKPOINT_DIR=

# --- GPU (PyTorch native, no code change needed) ----------------
# Uncomment and set these if you have multiple GPUs or need to tune memory
# CUDA_VISIBLE_DEVICES=0
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
